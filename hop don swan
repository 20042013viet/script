-- SCRIPT THỬ NGHIỆM BUFFER/SPAM TIỀN QUA REMOTE EVENT
-- Lưu ý: Cậu cần phải biết chính xác tên của RemoteEvent kiếm tiền trong game đó.

local ReplicatedStorage = game:GetService("ReplicatedStorage")

-- 1. Tìm nơi chứa các lệnh gửi lên Server (Thường nằm trong ReplicatedStorage)
-- Cậu hãy đổi chữ "AddMoneyEvent" thành tên cái RemoteEvent có trong game cậu chơi
local moneyEvent = ReplicatedStorage:FindFirstChild("AddMoneyEvent") 
                or ReplicatedStorage:FindFirstChild("RewardEvent")
                or ReplicatedStorage:FindFirstChild("ClickEvent")

if moneyEvent and moneyEvent:IsA("RemoteEvent") then
    print("Đã tìm thấy cổng gửi lệnh! Đang tiến hành spam lấy tiền thật...")
    
    -- Vòng lặp spam lệnh 100 lần để nhận tiền liên tục
    for i = 1, 100 do
        -- Gửi lệnh lên Server. 
        -- Có game chỉ cần gọi (), có game cần điền số tiền ví dụ: (1000000)
        moneyEvent:FireServer(1000000) 
        task.wait(0.1) -- Nghỉ 0.1 giây mỗi lần tránh bị game phát hiện kích văng
    end
    
    print("Đã chạy xong script. Hãy kiểm tra xem tiền có tiêu được không!")
else
    print("Không tìm thấy RemoteEvent phù hợp. Script không thể hoạt động trên game này.")
end
