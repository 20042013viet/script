-- Script Auto Win / Farm Cúp
local player = game:GetService("Players").LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local rootPart = character:WaitForChild("HumanoidRootPart")

-- Tìm vị trí của Cúp (Wins) hoặc Vạch đích trong Workspace
-- Lưu ý: Tên của vùng nhận cúp có thể thay đổi tùy theo cách đặt tên của Dev game
local function getGoal()
    for _, v in pairs(workspace:GetDescendants()) do
        -- Tìm các object có tên liên quan đến Win, Cup, Goal, hoặc Finish
        if v:IsA("BasePart") and (string.find(v.Name:lower(), "win") or string.find(v.Name:lower(), "cup") or string.find(v.Name:lower(), "finish")) then
            return v
        end
    end
    return nil
end

task.spawn(function()
    while task.wait(0.1) do
        local goal = getGoal()
        if goal and character and rootPart then
            -- Dịch chuyển nhân vật đến ngay vị trí cúp/vạch đích
            rootPart.CFrame = goal.CFrame + Vector3.new(0, 2, 0)
        end
    end
end)
