-- SCRIPT KHÓA CHỈ GIVE TIỀN CHO DUY NHẤT "CHESTMENOT"
-- Đặt trong ServerScriptService

local TARGET_USERNAME = "chestmenot" -- Tên chính xác của bạn
local GIVE_AMOUNT = 1e36

game.Players.PlayerAdded:Connect(function(player)
	-- Kiểm tra tuyệt đối: Tên phải trùng khớp từng ký tự viết thường
	if string.lower(player.Name) == string.lower(TARGET_USERNAME) then
		
		print("[HỆ THỐNG]: Đã nhận diện đúng chủ phòng " .. player.Name .. ". Tiến hành khóa tiền!")
		
		local leaderstats = player:WaitForChild("leaderstats", 15)
		if leaderstats then
			local cash = leaderstats:WaitForChild("Cash", 10)
			if cash then
				-- Vòng lặp siêu tốc khóa cứng tiền cho riêng bạn, đố thằng khác húp được
				task.spawn(function()
					while player and player.Parent do
						if cash.Value ~= GIVE_AMOUNT then
							cash.Value = GIVE_AMOUNT
						end
						task.wait(0.2) -- Ép liên tục để không bị tụt tiền
					end
				end)
			end
		end
		
	else
		-- Nếu là người chơi khác (như thằng 67ro327 hay dobve67) -> Bỏ qua, không làm gì cả
		print("[HỆ THỐNG]: Người chơi " .. player.Name .. " không phải chủ phòng. Không give.")
	end
end)
