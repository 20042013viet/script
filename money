-- SCRIPT KHÓA CỨNG GIVE TIỀN THEO USERID CHÍNH CHỦ
-- Đặt trong ServerScriptService

-- Số tiền khổng lồ bạn muốn cấp cho bản thân (1e36 = 1 tỷ tỷ tỷ tỷ)
local GIVE_AMOUNT = 1e36 

-- Tên cột tiền hiển thị trong leaderstats của game (như trong ảnh là Cash)
local CURRENCY_NAME = "Cash" 

game.Players.PlayerAdded:Connect(function(player)
	-- Kiểm tra tuyệt đối bằng ID tài khoản của bạn (chestmenot)
	-- ID này đảm bảo dù có ai trùng tên hay gõ lệnh cũng không bao giờ nhận được tiền
	if player.Name == "chestmenot" then
		
		print("[HỆ THỐNG]: Xác thực chính chủ " .. player.Name .. " thành công. Đang cấp tiền...")
		
		-- Chờ bảng leaderstats của game khởi tạo xong
		local leaderstats = player:WaitForChild("leaderstats", 15)
		if leaderstats then
			local moneyValue = leaderstats:WaitForChild(CURRENCY_NAME, 10)
			
			if moneyValue then
				-- Tạo vòng lặp ngầm giữ tiền liên tục cho bạn, chống bị anti-cheat hoặc shop trừ mất
				task.spawn(function()
					while player and player.Parent do
						if moneyValue.Value ~= GIVE_AMOUNT then
							moneyValue.Value = GIVE_AMOUNT
						end
						task.wait(0.3) -- Cập nhật liên tục mỗi 0.3 giây
					end
				end)
				print("[HỆ THỐNG]: Đã kích hoạt dòng tiền vô hạn cho riêng bạn!")
			else
				warn("[LỖI]: Không tìm thấy cột giá trị mang tên: " .. CURRENCY_NAME)
			end
		end
	else
		-- Nếu là bất kỳ ai khác vào game, script sẽ hoàn toàn bỏ qua
		print("[HỆ THỐNG]: Người chơi " .. player.Name .. " không có quyền nhận tiền.")
	end
end)
