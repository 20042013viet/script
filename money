-- SCRIPT TỰ ĐỘNG GIVE TIỀN CHO CHESTMENOT (SERVER SCRIPT)
-- Đặt trong ServerScriptService

local TARGET_PLAYER = "chestmenot" -- Đã sửa chính xác theo tên trong ảnh mới
local GIVE_AMOUNT = 1e99           -- Số tiền khổng lồ (1 tỷ tỷ tỷ tỷ)

game.Players.PlayerAdded:Connect(function(player)
	-- Kiểm tra nếu đúng là bạn vào game
	if player.Name == TARGET_PLAYER then
		
		-- Đợi bảng leaderstats của game load xong
		local leaderstats = player:WaitForChild("leaderstats", 10)
		
		if leaderstats then
			-- Tìm cột Cash để cộng tiền
			local cash = leaderstats:WaitForChild("Cash", 5)
			if cash then
				-- Khóa số tiền của bạn luôn ở mức 1e36
				task.spawn(function()
					while player and player.Parent do
						if cash.Value ~= GIVE_AMOUNT then
							cash.Value = GIVE_AMOUNT
						end
						task.wait(0.5) -- Kiểm tra và giữ tiền liên tục mỗi 0.5 giây
					end
				end)
				print("[HỆ THỐNG VIP]: Đã tự động kích hoạt Give tiền cho " .. player.Name)
			end
		end
		
	end
end)
