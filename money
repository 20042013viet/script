-- SCRIPT KHÓA CỨNG GIVE TIỀN THEO USERID CHO CHESTMENOT
-- Đặt trong ServerScriptService

local GIVE_AMOUNT = 1e36 
local CURRENCY_NAME = "Cash" 

game.Players.PlayerAdded:Connect(function(player)
	-- KIỂM TRA BẢO MẬT: Trùng tên HOẶC trùng ID máy chủ test (UserId <= 0 dành cho Local Server Studio)
	-- Cách này giúp nhận diện chính xác 100% bạn mà không sợ lỗi viết hoa/thường hay DisplayName
	if string.lower(player.Name) == "chestmenot" or player.UserId <= 0 then
		
		print("[HỆ THỐNG BẢO MẬT]: Đã xác minh chính chủ " .. player.Name .. " (ID: " .. player.UserId .. "). Đang kích hoạt kho tiền...")
		
		-- Đợi bảng leaderstats của game khởi tạo xong
		local leaderstats = player:WaitForChild("leaderstats", 15)
		if leaderstats then
			local cashValue = leaderstats:WaitForChild(CURRENCY_NAME, 10)
			
			if cashValue then
				-- Vòng lặp ngầm siêu tốc khóa cứng tiền cho riêng bạn
				task.spawn(function()
					while player and player.Parent do
						if cashValue.Value ~= GIVE_AMOUNT then
							cashValue.Value = GIVE_AMOUNT
						end
						task.wait(0.2) -- Cập nhật liên tục mỗi 0.2 giây để mua sắm tẹt ga không lo hết
					end
				end)
				print("[HỆ THỐNG VIP]: Kích hoạt dòng tiền vô hạn thành công!")
			end
		end
	else
		-- Người chơi khác (hoặc các clone phá đám) sẽ hoàn toàn bị ngó lơ
		print("[HỆ THỐNG]: Bỏ qua người chơi " .. player.Name .. ", không có quyền nhận tiền.")
	end
end)
