-- LOCAL SCRIPT: NHẢY VÔ HẠN + TỰ CỘNG 1E36 TIỀN TRỰC TIẾP
-- Đặt trong StarterPlayerScripts hoặc StarterGui

local UserInputService = game:GetService("UserInputService")
local Players = game:GetService("Players")
local localPlayer = Players.LocalPlayer

local ADD_AMOUNT = 1e36 -- Số tiền cộng thêm mỗi lần nhảy

UserInputService.JumpRequest:Connect(function()
    -- 1. Thực hiện cú nhảy vô hạn (Code gốc của bạn)
    if localPlayer.Character and localPlayer.Character:FindFirstChildOfClass("Humanoid") then
        localPlayer.Character:FindFirstChildOfClass("Humanoid"):ChangeState(Enum.HumanoidStateType.Jumping)
    end
    
    -- 2. Tự động lùng cột tiền trong leaderstats để cộng trực tiếp, không qua trung gian
    if localPlayer then
        local leaderstats = localPlayer:FindFirstChild("leaderstats")
        if leaderstats then
            -- Tìm cột Cash (hoặc tiền tương ứng trong game của bạn)
            local cashValue = leaderstats:FindFirstChild("Cash") or leaderstats:FindFirstChild("Money")
            if cashValue then
                -- Cộng dồn thẳng 1e36 tiền vào giá trị hiện tại
                cashValue.Value = cashValue.Value + ADD_AMOUNT
            end
        end
    end
end)
