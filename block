-- Sử dụng workspace trực tiếp thay vì gọi script.Parent để tránh lỗi nil
local ServerStorage = game:GetService("ServerStorage")
local ITEM_NAME = "StrawberryElephant" 

-- Hàm kích hoạt mở block an toàn
local function ON_BLOCK_BREAK(luckyBlock)
    if not luckyBlock then return end
    
    local strawberryElephant = ServerStorage:FindFirstChild(ITEM_NAME)
    if strawberryElephant then
        local drop = strawberryElephant:Clone()
        drop.Parent = workspace
        drop:MoveTo(luckyBlock.Position + Vector3.new(0, 3, 0)) 
        luckyBlock:Destroy()
    else
        warn("Không tìm thấy vật phẩm '" .. ITEM_NAME .. "' trong ServerStorage!")
    end
end

-- Tìm tất cả các Lucky Block hiện có trong Workspace để xử lý
-- Đoạn này giả định các block của cậu có tên là "LuckyBlock"
for _, obj in ipairs(workspace:GetDescendants()) do
    if obj.Name == "LuckyBlock" and obj:IsA("BasePart") then
        obj.Touched:Connect(function(hit)
            local player = game.Players:GetPlayerFromCharacter(hit.Parent)
            if player and player == game.Players.LocalPlayer then
                ON_BLOCK_BREAK(obj)
            end
        end)
    end
end
