-- Thay tên "LeaderstatsName" bằng tên bảng điểm trong game (thường là "leaderstats")
-- Thay tên "CurrencyName" bằng tên loại tiền trong game (ví dụ: "Cash", "Money", "Gold", "Coins")

local localPlayer = game:GetService("Players").LocalPlayer
local leaderstats = localPlayer:WaitForChild("leaderstats", 5) -- Tìm bảng điểm

if leaderstats then
    -- Tìm loại tiền trong bảng điểm
    -- Hãy đổi chữ "Cash" thành tên loại tiền chính xác của game cậu đang chơi nhé
    local moneyValue = leaderstats:FindFirstChild("Cash") or leaderstats:FindFirstChild("Money")
    
    if moneyValue then
        -- Buff con số lên 1 tỷ tỷ tỷ tỷ (10^24)
        moneyValue.Value = 1000000000000000000000000 
        print("Đã buff tiền thành công! Nhìn giàu chưa kìa?")
    else
        print("Không tìm thấy tên loại tiền phù hợp. Hãy kiểm tra lại tên biến!")
    end
else
    print("Không tìm thấy bảng leaderstats của người chơi.")
end
