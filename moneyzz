-- SCRIPT SERVER - ĐỔI TIỀN THẬT TRONG GAME CỦA BẠN
game.Players.PlayerAdded:Connect(function(player)
    -- Tạo bảng lưu trữ dữ liệu cho người chơi
    local leaderstats = Instance.new("Folder")
    leaderstats.name = "leaderstats"
    leaderstats.Parent = player

    -- Tạo biến Tiền
    local money = Instance.new("NumberValue") -- Dùng NumberValue để chứa được số lớn 1e24
    money.Name = "Money"
    
    -- Cộng tiền thật trên Server (chỉ có tác dụng trong game do bạn làm chủ)
    money.Value = 1e24
    money.Parent = leaderstats
end)
