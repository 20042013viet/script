-- SCRIPT CHỐNG CHẾT DO DUNG NHAM & VOID (SERVER SCRIPT)
-- Đặt trong ServerScriptService

game.Players.PlayerAdded:Connect(function(player)
    player.CharacterAdded:Connect(function(character)
        local hrp = character:WaitForChild("HumanoidRootPart")
        local humanoid = character:WaitForChild("Humanoid")
        
        -- 1. Khóa trạng thái chết của Roblox (Không cho game ép nhân vật chết)
        humanoid:SetStateEnabled(Enum.HumanoidStateType.Dead, false)
        
        -- 2. Vòng lặp kiểm tra va chạm để xóa các thứ làm bạn chết
        task.spawn(function()
            while character and character.Parent do
                -- Quét xung quanh nhân vật xem có phần tử dung nham nào chạm vào không
                local touchingParts = hrp:GetTouchingParts()
                for _, part in pairs(touchingParts) do
                    -- Nếu chạm vào khối gạch có tên là Lava hoặc Dung nham (bạn có thể đổi tên cho đúng cấu trúc map)
                    if string.find(string.lower(part.Name), "lava") or string.find(string.lower(part.Name), "kill") then
                        -- Tắt tính năng làm đau của khối đó đối với bạn
                        part.CanTouch = false
                    end
                end
                
                -- Đề phòng dung nham dâng lên quá cao dìm bạn xuống vị trí Void
                -- Nếu bạn bị rơi xuống dưới mức bản đồ (ví dụ độ cao Y < -100) thì tự động dịch chuyển lên trên
                if hrp.Position.Y < -50 then
                    hrp.CFrame = CFrame.new(hrp.Position.X, 50, hrp.Position.Z)
                    humanoid.Health = humanoid.MaxHealth
                end
                
                task.wait(0.1)
            end
        end)
    end
end)
