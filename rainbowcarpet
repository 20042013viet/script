-- Hàm tự động tạo vật phẩm và đưa vào túi đồ người chơi
local function giveItem(player, itemName, itemColor, itemSize)
    local backpack = player:WaitForChild("Backpack")
    
    -- 1. Tạo Tool và đặt tên theo ý muốn
    local tool = Instance.new("Tool")
    tool.Name = itemName
    
    -- 2. Tạo phần tay cầm (Handle) để nhân vật cầm được
    local handle = Instance.new("Part")
    handle.Name = "Handle"
    handle.Size = itemSize or Vector3.new(1, 1, 1) -- Kích thước mặc định
    handle.Color = itemColor or Color3.fromRGB(255, 255, 255) -- Màu sắc mặc định
    handle.Material = Enum.Material.Neon -- Chất liệu phát sáng để dễ nhận biết khi test
    handle.Parent = tool
    
    -- 3. Đưa vật phẩm vào túi đồ
    tool.Parent = backpack
end

